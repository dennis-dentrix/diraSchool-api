# ============================================================
# Diraschool API — Local/Dev Example
# Copy to: apps/api/.env
# ============================================================

# Required core
NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://localhost:27017/diraschool
REDIS_URL=redis://localhost:6379
JWT_SECRET=CHANGE_ME_MINIMUM_32_RANDOM_CHARS
JWT_EXPIRES_IN=1d
CLIENT_URL=http://localhost:5173
CLIENT_URL_STAGING=
SCHOOL_RATE_LIMIT=300

# Email — ZeptoMail is primary; set RESEND_API_KEY for automatic fallback
EMAIL_FROM=Diraschool <noreply@yourdomain.com>
ZEPTOMAIL_SERVER=smtp.zeptomail.com
ZEPTOMAIL_USERNAME=emailapikey
ZEPTOMAIL_API_KEY=
RESEND_API_KEY=

# SMS (optional)
AT_USERNAME=sandbox
AT_API_KEY=atsk_69c2e4b8614f088c48420cc117a09095a055de564979dc12343cd4c53dedadf49e471d9d
AT_SENDER_ID=SCHOOL
AT_SANDBOX_MODE=true


# DigitalOcean Spaces (optional — file uploads skipped when not set)
# Create a Space in your DO account, then generate Spaces access keys
# under API > Spaces Keys. All 4 must be set or none.
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=diraschool-media
DO_SPACES_REGION=ams3
# CDN endpoint (optional) — enable CDN on the Space in DO dashboard, then paste the endpoint
# Example: https://diraschool-media.ams3.cdn.digitaloceanspaces.com
DO_SPACES_CDN_ENDPOINT=

# Sentry (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ALLOW_PROD_TEST_ENDPOINT=false

# Pesapal subscription checkout (optional)
PESAPAL_ENABLED=false
PESAPAL_ENV=sandbox
# Override only if Pesapal changes URLs
PESAPAL_BASE_URL=
PESAPAL_CONSUMER_KEY=321xf4jHqKYXOPP/HeatlFsQf2321JHi
PESAPAL_CONSUMER_SECRET=D1/VJ8RRrAaM+PUw6qaXlD+tQdU=

# Create/register IPN URL in Pesapal and paste the Notification ID here
PESAPAL_NOTIFICATION_ID=
PESAPAL_CURRENCY=KES
