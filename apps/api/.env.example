# ============================================================
# Diraschool API — Environment Variables
# Copy this file to .env and fill in all required values.
# This file is committed to the repo. .env is never committed.
# ============================================================

# ── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ────────────────────────────────────────────────
# Local (Docker): mongodb://localhost:27017/diraschool
# DO Managed:     mongodb+srv://user:pass@host/diraschool?authSource=admin&tls=true
MONGO_URI=mongodb://localhost:27017/diraschool

# ── Auth ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_minimum_32_random_characters_here
JWT_EXPIRES_IN=1d

# ── CORS ─────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
CLIENT_URL_STAGING=

# ── Redis ────────────────────────────────────────────────────
# Local (Docker): redis://localhost:6379
# DO Managed:     rediss://default:password@host:25061
REDIS_URL=redis://localhost:6379

# ── Email (ZeptoMail primary + Resend fallback) ─────────────
# At least one provider must be configured.
# If ZeptoMail fails (quota/network/provider errors), API falls back to Resend.
EMAIL_FROM=Diraschool <noreply@yourdomain.co.ke>

# ZeptoMail — primary provider
# 1. Sign up at https://zeptomail.com
# 2. Mail Agents → Add Mail Agent → enter your domain
# 3. Add the SPF + DKIM + bounce DNS records to your registrar
# 4. Verify → copy API key from the SMTP tab
# SMTP username is always the literal string: emailapikey
ZEPTOMAIL_API_KEY=your_zeptomail_api_key_here
ZEPTOMAIL_SERVER=smtp.zeptomail.com
ZEPTOMAIL_USERNAME=emailapikey

# Resend — fallback provider
# https://resend.com/api-keys  — domain must be verified in Resend dashboard
RESEND_API_KEY=re_your_resend_api_key_here

# ── Africa's Talking (SMS) ───────────────────────────────────
# Use 'sandbox' for AT_USERNAME in development
# Get API key from: https://account.africastalking.com
AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key_here
AT_SENDER_ID=SCHOOL

# ── Cloudinary (file storage) — Phase 6 ────────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Monitoring — Phase 5 ────────────────────────────────────
# SENTRY_DSN=
