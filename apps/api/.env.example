# ============================================================
# Diraschool API — Environment Variables
# Copy this file to .env and fill in all required values.
# This file is committed to the repo. .env is never committed.
# ============================================================

# ── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ────────────────────────────────────────────────
# Local (Docker): mongodb://localhost:27017/diraschool
# DO Managed:     mongodb+srv://user:pass@host/diraschool?authSource=admin&tls=true
MONGO_URI=mongodb://localhost:27017/diraschool

# ── Auth ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_minimum_32_random_characters_here
JWT_EXPIRES_IN=1d

# ── CORS ─────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
CLIENT_URL_STAGING=

# ── Redis ────────────────────────────────────────────────────
# Local (Docker): redis://localhost:6379
# DO Managed:     rediss://default:password@host:25061
REDIS_URL=redis://localhost:6379

<<<<<<< HEAD
# ── Email ────────────────────────────────────────────────────
# Primary: Resend (tried first). Fallback: ZeptoMail (automatic if Resend fails/quota hit).
# Set both for full resilience. EMAIL_FROM domain must be verified in BOTH providers.
EMAIL_FROM=Diraschool <noreply@yourdomain.co.ke>

# Resend — primary (3,000 emails/month free)
# Verify your domain at: https://resend.com/domains
# Get API key at:        https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# ZeptoMail — fallback (10,000 one-time free, then ~$2.50 per 10k — pay-as-you-go)
# 1. Sign up at https://zeptomail.com
# 2. Mail Agents → Add Mail Agent → enter your domain
# 3. Add the SPF + DKIM + bounce DNS records they provide to your registrar
# 4. Verify in ZeptoMail dashboard → copy API key from the SMTP tab
# SMTP username is always the literal string: emailapikey
ZEPTOMAIL_API_KEY=your_zeptomail_api_key_here
