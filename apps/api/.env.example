# ============================================================
# Diraschool API — Local/Dev Example
# Copy to: apps/api/.env
# ============================================================

# Required core
NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://localhost:27017/diraschool
REDIS_URL=redis://localhost:6379
JWT_SECRET=CHANGE_ME_MINIMUM_32_RANDOM_CHARS
JWT_EXPIRES_IN=1d
CLIENT_URL=http://localhost:5173
CLIENT_URL_STAGING=
SCHOOL_RATE_LIMIT=300

# Email — ZeptoMail API
# Paste the Send Mail token from ZeptoMail's API tab. The app accepts either
# the raw token or the full "Zoho-enczapikey <token>" authorization value.
EMAIL_FROM=Diraschool <noreply@yourdomain.com>
ZEPTOMAIL_API_KEY=CHANGE_ME
ZEPTOMAIL_API_URL=api.zeptomail.com/

# SMS — Celcom Africa (optional until messaging is enabled)
# Get API Key and Partner ID from the Celcom Africa dashboard.
SMS_PROVIDER=celcom
CELCOM_PARTNER_ID=
CELCOM_API_KEY=
CELCOM_SHORTCODE=DIRASCHOOL
# Generic platform Sender ID. Defaults to CELCOM_SHORTCODE when left blank.
SMS_PLATFORM_SENDER_ID=
# Comma-separated E.164 numbers. When set, ALL SMS (incl. broadcasts) go ONLY
# to these numbers — prevents real users from being messaged during dev/QA.
SMS_TEST_NUMBERS=+254115879589,+254700834550

# Legacy fallback only if SMS_PROVIDER=africastalking.
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=


# DigitalOcean Spaces (optional — file uploads skipped when not set)
# Create a Space in your DO account, then generate Spaces access keys
# under API > Spaces Keys. All 4 must be set or none.
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=diraschool-media
DO_SPACES_REGION=ams3
# CDN endpoint (optional) — enable CDN on the Space in DO dashboard, then paste the endpoint
# Example: https://diraschool-media.ams3.cdn.digitaloceanspaces.com
DO_SPACES_CDN_ENDPOINT=

# Sentry (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ALLOW_PROD_TEST_ENDPOINT=false

# Paystack subscription checkout
# Get your secret key from https://dashboard.paystack.com/#/settings/developers
# Register webhook URL: https://api.yourdomain.com/api/v1/subscriptions/paystack/webhook
PAYSTACK_ENABLED=false
PAYSTACK_SECRET_KEY=

# Safaricom Daraja C2B callback registration
# Production base URL: https://api.safaricom.co.ke
# Sandbox base URL: https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_ENV=production
MPESA_BASE_URL=https://api.safaricom.co.ke
MPESA_CALLBACK_BASE_URL=https://api.diraschool.com
# Production defaults to IP whitelist enabled. Add comma-separated IPs here if
# Safaricom changes callback ranges or you need sandbox/test callback IPs.
MPESA_IP_WHITELIST_ENABLED=true
MPESA_ALLOWED_IPS=
