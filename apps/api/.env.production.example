# ============================================================
# Diraschool API — Production Example
# Copy values into your production process manager (PM2/ecosystem)
# or into apps/api/.env on the server.
# ============================================================

NODE_ENV=production
PORT=3000

# Required core
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/diraschool?retryWrites=true&w=majority
REDIS_URL=rediss://default:PASSWORD@HOST:6379
JWT_SECRET=CHANGE_ME_MINIMUM_32_RANDOM_CHARS
JWT_EXPIRES_IN=1d
CLIENT_URL=https://www.diraschool.com
CLIENT_URL_STAGING=https://staging.diraschool.com
SCHOOL_RATE_LIMIT=300

# Email (at least one provider key is required)
EMAIL_FROM=Diraschool <onboarding@contact.diraschool.com>
EMAIL_PRIMARY_PROVIDER=zeptomail
EMAIL_FAILOVER_ENABLED=true
ZEPTOMAIL_SERVER=smtp.zeptomail.com
ZEPTOMAIL_USERNAME=emailapikey
ZEPTOMAIL_API_KEY=
RESEND_API_KEY=

# SMS (optional)
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=SCHOOL

# Cloudinary (optional, but if one is set all three must be set)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Sentry (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ALLOW_PROD_TEST_ENDPOINT=false
