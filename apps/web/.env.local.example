# Copy to .env.local
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:5173

# Feature flags
# Set to "true" on staging to enable the SMS Messaging feature; leave unset on production (shows Coming Soon)
NEXT_PUBLIC_MESSAGING_ENABLED=true
# Mirror of SMS_TEST_NUMBERS in the API — shows a warning banner in the messaging UI.
NEXT_PUBLIC_SMS_TEST_NUMBERS=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENABLED=false
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0.0
NEXT_PUBLIC_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=1.0
SENTRY_DSN=
SENTRY_ENABLED=false
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
