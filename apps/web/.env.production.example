# ============================================================
# Diraschool Web — Production Example
# Use on server for `next build` and `next start`.
# ============================================================

# Public runtime values used by browser + server components
NEXT_PUBLIC_API_URL=https://api.diraschool.com
NEXT_PUBLIC_APP_URL=https://www.diraschool.com

# Sentry runtime (optional)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0.0
NEXT_PUBLIC_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=1.0
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Sentry source-map upload during build (optional)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# E2E testing (optional)
PLAYWRIGHT_BASE_URL=https://www.diraschool.com
