{
  "name": "diraschool",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "dev:all": "concurrently \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "start": "npm run start -w apps/api",
    "worker": "npm run worker -w apps/api",
    "build:web": "npm run build -w apps/web",
    "start:web": "npm run start -w apps/web",
    "test": "npm test -w apps/api",
    "test:e2e": "npm run test:e2e -w apps/web",
    "seed": "npm run seed -w apps/api",
    "lint": "npm run lint -w apps/api",
    "lint:web": "npm run lint -w apps/web"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
